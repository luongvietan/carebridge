{
  "name": "carebridge-connect",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @carebridge/web",
    "build": "npm run build -w @carebridge/web",
    "start": "npm run start -w @carebridge/web",
    "lint": "npm run lint -w @carebridge/web",
    "test": "npm run test -w @carebridge/web",
    "e2e": "npm run e2e -w @carebridge/web",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:test": "supabase test db",
    "db:push": "supabase db push"
  },
  "devDependencies": {
    "supabase": "^2.106.0"
  }
}
