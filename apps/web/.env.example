# CareBridge Connect — environment template
#
# Setup (local):
#   1. Copy this file:  cp .env.example .env.local
#   2. Start Supabase:  npx supabase start   (from repo root)
#   3. Fill Supabase keys from:  npx supabase status
#
# Never commit `.env.local` or real secrets. Values below are placeholders only.

# ── Supabase (required) ───────────────────────────────────────────────────────
# Local defaults shown in comments; use hosted project URL/keys for staging/prod.
# Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App URL (recommended) ─────────────────────────────────────────────────────
# Public site origin — used for auth email links, Stripe Checkout redirects, etc.
# Defaults to http://127.0.0.1:3000 when unset.

NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# ── Stripe (required for real payments & webhooks) ────────────────────────────
# Test keys from https://dashboard.stripe.com/test/apikeys
# Without STRIPE_SECRET_KEY the app uses stub customer IDs (local dev only).
# Webhook signing secret from Stripe CLI (`stripe listen`) or Dashboard endpoint.

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Payout bank details (required to save professional payout info) ───────────
# Symmetric key for pgcrypto encrypt/decrypt in Supabase RPCs.
# Generate once and keep stable:  openssl rand -base64 32
# Rotating this key makes existing encrypted bank details unreadable.

PAYOUT_ENC_KEY=

# ── Email / Resend (optional locally) ─────────────────────────────────────────
# When RESEND_API_KEY is unset, notifications are stored in DB only (no outbound email).
# Production: https://resend.com/api-keys

# RESEND_API_KEY=
# RESEND_FROM=CareBridge Connect <noreply@your-domain.com>

# ── Production access gate (Vercel production only) ───────────────────────────
# Soft gate before public launch — leave unset for local dev.
# When enabled, visitors must enter PRODUCTION_GATE_SECRET at /gate.
# Exempt paths: /gate, /api/stripe/webhook, /auth/confirm

# PRODUCTION_GATE_ENABLED=true
# PRODUCTION_GATE_SECRET=
