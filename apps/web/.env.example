# Copy to .env.local and fill from `npx supabase status` (local) or your hosted project settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Production access gate — set on Vercel production only. Leave unset locally.
# PRODUCTION_GATE_ENABLED=true
# PRODUCTION_GATE_SECRET=choose-a-long-random-passphrase
